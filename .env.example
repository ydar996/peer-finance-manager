# Render (API server)
NODE_ENV=production
PORT=10000
PFM_DATA_DIR=/var/data
ALLOWED_ORIGINS=https://your-site.netlify.app

# Netlify (set in Netlify dashboard → Site settings → Environment variables)
RENDER_API_URL=https://your-app.onrender.com
MEMBER_PORTAL_URL=https://your-site.netlify.app/member

# Email notifications (Render → Environment). Required for automatic member report emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=notifications@yourdomain.com
SMTP_FROM_NAME=Assurance Cooperative

# Supabase (optional backup / future use)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
