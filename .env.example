# Render (API server)
NODE_ENV=production
PORT=10000
PFM_DATA_DIR=/var/data
PFM_TIMEZONE=America/Los_Angeles
# Optional server fallback before a cooperative sets its own time zone in Admin → Organization Settings.
ALLOWED_ORIGINS=https://your-site.netlify.app

# Netlify (set in Netlify dashboard → Site settings → Environment variables)
RENDER_API_URL=https://your-app.onrender.com
MEMBER_PORTAL_URL=https://your-site.netlify.app/member

# Email notifications (Render → Environment). Use SMTP **or** Bluehost HTTPS relay (no extra vendor).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=notifications@yourdomain.com
SMTP_FROM_NAME=Assurance Cooperative

# Bluehost relay (recommended when Bluehost SMTP is refused from Render). See BLUEHOST-EMAIL-RELAY-SETUP.md
EMAIL_RELAY_URL=https://yourdomain.com/pfm-mail-relay.php
EMAIL_RELAY_SECRET=long-random-secret-matching-php-file

# Supabase (optional backup / future use)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
